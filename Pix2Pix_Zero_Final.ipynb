    "# ============================================================\n",
    "# Cell 3 — Apply all compatibility patches\n",
    "# ============================================================\n",
    "from pathlib import Path\n",
    "\n",
    "# ---------- Patch base_pipeline.py ----------\n",
    "p = Path(\"/content/pix2pix-zero/src/utils/base_pipeline.py\")\n",
    "txt = p.read_text()\n",
    "\n",
    "old_transformers = \"from transformers import CLIPFeatureExtractor, CLIPTextModel, CLIPTokenizer\"\n",
    "new_transformers = \"\"\"try:\n",
    "    from transformers import CLIPFeatureExtractor\n",
    "except ImportError:\n",
    "    from transformers import CLIPImageProcessor as CLIPFeatureExtractor\n",
    "from transformers import CLIPTextModel, CLIPTokenizer\"\"\"\n",
    "\n",
    "old_diffusers = \"from diffusers.utils import deprecate, is_accelerate_available, logging, randn_tensor, replace_example_docstring\"\n",
    "new_diffusers = \"\"\"from diffusers.utils import deprecate, is_accelerate_available, logging, replace_example_docstring\n",
    "try:\n",
    "    from diffusers.utils import randn_tensor\n",
    "except ImportError:\n",
    "    from diffusers.utils.torch_utils import randn_tensor\"\"\"\n",
    "\n",
    "if old_transformers in txt:\n",
    "    txt = txt.replace(old_transformers, new_transformers)\n",
    "if old_diffusers in txt:\n",
    "    txt = txt.replace(old_diffusers, new_diffusers)\n",
    "\n",
    "p.write_text(txt)\n",
    "print(\"Patched:\", p)\n",
    "\n",
    "# ---------- Patch scheduler.py ----------\n",
    "p = Path(\"/content/pix2pix-zero/src/utils/scheduler.py\")\n",
    "txt = p.read_text()\n",
    "\n",
    "old_sched = \"from diffusers.utils import BaseOutput, randn_tensor\"\n",
    "new_sched = \"\"\"from diffusers.utils import BaseOutput\n",
    "try:\n",
    "    from diffusers.utils import randn_tensor\n",
    "except ImportError:\n",
    "    from diffusers.utils.torch_utils import randn_tensor\"\"\"\n",
    "\n",
    "if old_sched in txt:\n",
    "    txt = txt.replace(old_sched, new_sched)\n",
    "\n",
    "p.write_text(txt)\n",
    "print(\"Patched:\", p)\n",
    "\n",
    "# ---------- Replace cross_attention.py ----------\n",
    "patched_cross_attention = \"\"\"\n",
    "import torch\n",
    "\n",
    "try:\n",
    "    from diffusers.models.attention import CrossAttention\n",
    "except ImportError:\n",
    "    from diffusers.models.attention import Attention as CrossAttention\n",
    "\n",
    "\n",
    "class MyCrossAttnProcessor:\n",
    "    def __call__(\n",
    "        self,\n",
    "        attn: CrossAttention,\n",
    "        hidden_states,\n",
    "        encoder_hidden_states=None,\n",
    "        attention_mask=None,\n",
    "        *args,\n",
    "        **kwargs\n",
    "    ):\n",
    "        batch_size, sequence_length, _ = (\n",
    "            hidden_states.shape if encoder_hidden_states is None else encoder_hidden_states.shape\n",
    "        )\n",
    "\n",
    "        attention_mask = attn.prepare_attention_mask(\n",
    "            attention_mask, sequence_length, batch_size\n",
    "        )\n",
    "\n",
    "        query = attn.to_q(hidden_states)\n",
    "\n",
    "        encoder_hidden_states = (\n",
    "            encoder_hidden_states if encoder_hidden_states is not None else hidden_states\n",
    "        )\n",
    "\n",
    "        key = attn.to_k(encoder_hidden_states)\n",
    "        value = attn.to_v(encoder_hidden_states)\n",
    "\n",
    "        query = attn.head_to_batch_dim(query)\n",
    "        key = attn.head_to_batch_dim(key)\n",
    "        value = attn.head_to_batch_dim(value)\n",
    "\n",
    "        attention_probs = attn.get_attention_scores(query, key, attention_mask)\n",
    "\n",
    "        attn.attn_probs = attention_probs\n",
    "\n",
    "        hidden_states = torch.bmm(attention_probs, value)\n",
    "        hidden_states = attn.batch_to_head_dim(hidden_states)\n",
    "\n",
    "        hidden_states = attn.to_out[0](hidden_states)\n",
    "        hidden_states = attn.to_out[1](hidden_states)\n",
    "\n",
    "        return hidden_states\n",
    "\n",
    "\n",
    "def prep_unet(unet):\n",
    "    for name, params in unet.named_parameters():\n",
    "        if 'attn2' in name:\n",
    "            params.requires_grad = True\n",
    "        else:\n",
    "            params.requires_grad = False\n",
    "\n",
    "    for name, module in unet.named_modules():\n",
    "        module_name = type(module).__name__\n",
    "        if module_name in [\"CrossAttention\", \"Attention\"]:\n",
    "            module.set_processor(MyCrossAttnProcessor())\n",
    "\n",
    "    return unet\n",
    "\"\"\"\n",
    "p = Path(\"/content/pix2pix-zero/src/utils/cross_attention.py\")\n",
    "p.write_text(patched_cross_attention)\n",
    "print(\"Patched:\", p)\n",
    "\n",
    "# ---------- Patch edit_pipeline.py ----------\n",
    "p = Path(\"/content/pix2pix-zero/src/utils/edit_pipeline.py\")\n",
    "txt = p.read_text()\n",
    "\n",
    "txt = txt.replace(\n",
    "    'if module_name == \\\"CrossAttention\\\" and \\\'attn2\\\' in name:',\n",
    "    'if module_name in [\\\"CrossAttention\\\", \\\"Attention\\\"] and \\\'attn2\\\' in name:'\n",
    ")\n",
    "txt = txt.replace(\n",
    "    'loss = 0.0',\n",
    "    'loss = torch.tensor(0.0, device=device, dtype=x_in.dtype)'\n",
    ")\n",
    "\n",
    "p.write_text(txt)\n",
    "print(\"Patched:\", p)"
   ]
