    "# ============================================================\n",
    "# Cell 1 — Clone repo and install dependencies\n",
    "# ============================================================\n",
    "%cd /content\n",
    "import os\n",
    "\n",
    "if not os.path.exists(\"/content/pix2pix-zero\"):\n",
    "    !git clone https://github.com/pix2pixzero/pix2pix-zero.git\n",
    "\n",
    "%cd /content/pix2pix-zero\n",
    "\n",
    "!pip install -q -U pip setuptools wheel\n",
    "!pip install -q -U \\\n",
    "    \"tokenizers>=0.15.2\" \\\n",
    "    \"transformers>=4.39.0\" \\\n",
    "    \"diffusers>=0.27.0\" \\\n",
    "    \"accelerate>=0.27.0\" \\\n",
    "    \"huggingface_hub>=0.21.0\" \\\n",
    "    ftfy sentencepiece safetensors omegaconf einops \\\n",
    "    matplotlib \"pillow<12\" opencv-python ipywidgets jedi"
   ]
